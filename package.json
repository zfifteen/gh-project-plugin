{
  "name": "gh-project-plugin",
  "version": "0.1.0",
  "description": "Codex plugin bundle for creating GitHub repositories with low-friction defaults and native menu prompts.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zfifteen/gh-project-plugin.git"
  },
  "homepage": "https://github.com/zfifteen/gh-project-plugin#readme",
  "bugs": {
    "url": "https://github.com/zfifteen/gh-project-plugin/issues"
  },
  "keywords": [
    "codex",
    "codex-plugin",
    "github",
    "github-cli",
    "mcp",
    "repository",
    "project-setup",
    "workflow-automation"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    ".codex-plugin/",
    ".mcp.json",
    "mcp-server/",
    "research/",
    "release-readiness-checklist.md",
    "scripts/",
    "skills/",
    "spec.html"
  ],
  "scripts": {
    "mcp": "node mcp-server/server.mjs",
    "probe": "node scripts/probe-client.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "validate": "npm run probe && npm run pack:dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  }
}
